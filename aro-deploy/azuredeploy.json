        "[resourceId('Microsoft.Authorization/roleAssignments', guid(resourceGroup().id, variables('platformIdentityResourceIds')[6], variables('storageBlobDataContribId')))]",
        "[extensionResourceId(resourceId('Microsoft.Network/virtualNetworks', format('{0}-vnet', parameters('clusterName'))), 'Microsoft.Authorization/roleAssignments', guid(resourceId('Microsoft.Network/virtualNetworks', format('{0}-vnet', parameters('clusterName'))), variables('platformIdentityResourceIds')[7], variables('networkContributorRoleId')))]",
