        "description": "ARO API server URL."
      },
      "value": "[if(variables('deployCluster'), reference(resourceId('Microsoft.RedHatOpenShift/openShiftClusters', parameters('clusterName')), '2024-08-12-preview').apiserverProfile.url, '')]"
    },
    "clusterIdentityId": {
      "type": "string",
      "metadata": {
        "description": "Cluster identity resource ID."
      },
      "value": "[variables('clusterIdentityResourceId')]"
    }
  }
}