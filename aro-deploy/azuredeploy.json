{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "17234927534052672297"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources."
      }
    },
    "clusterName": {
      "type": "string",
      "metadata": {
        "description": "Name of the ARO cluster."
      }
    },
    "clusterVersion": {
      "type": "string",
      "defaultValue": "4.19.20",
      "metadata": {
        "description": "OpenShift Container Platform version."
      }
    },
    "domain": {
      "type": "string",
      "defaultValue": "[parameters('clusterName')]",
      "metadata": {
        "description": "Domain prefix for the cluster (used in API/console URLs)."
      }
    },
    "clusterResourceGroupId": {
      "type": "string",
      "metadata": {
        "description": "Resource group where ARO places cluster infrastructure (VMs, LBs). Must differ from this RG and must NOT already exist."
      }
    },
    "pullSecret": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Pull secret from https://console.redhat.com/openshift/install/pull-secret. Optional."
      }
    },
    "masterVmSize": {
      "type": "string",
      "defaultValue": "Standard_D8s_v3",
      "metadata": {
        "description": "Master node VM size."
      }
    },
    "workerVmSize": {
      "type": "string",
      "defaultValue": "Standard_D4s_v3",
      "metadata": {
        "description": "Worker node VM size."
      }
    },
    "workerCount": {
      "type": "int",
      "defaultValue": 3,
      "minValue": 2,
      "metadata": {
        "description": "Number of worker nodes (minimum 2)."
      }
    },
    "workerDiskSizeGB": {
      "type": "int",
      "defaultValue": 128,
      "minValue": 128,
      "metadata": {
        "description": "Worker node OS disk size in GB (minimum 128)."
      }
    },
    "apiServerVisibility": {
      "type": "string",
      "defaultValue": "Public",
      "allowedValues": [
        "Public",
        "Private"
      ],
      "metadata": {
        "description": "API server visibility."
      }
    },
    "ingressVisibility": {
      "type": "string",
      "defaultValue": "Public",
      "allowedValues": [
        "Public",
        "Private"
      ],
      "metadata": {
        "description": "Ingress visibility."
      }
    },
    "podCidr": {
      "type": "string",
      "defaultValue": "10.128.0.0/14",
      "metadata": {
        "description": "Pod CIDR. Must not overlap with VNet address space."
      }
    },
    "serviceCidr": {
      "type": "string",
      "defaultValue": "172.30.0.0/16",
      "metadata": {
        "description": "Service CIDR. Must not overlap with VNet address space."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {
        "environment": "demo",
        "managedBy": "bicep",
        "aroVersion": "4.19"
      },
      "metadata": {
        "description": "Tags to apply to all resources."
      }
    },
    "deploymentMode": {
      "type": "string",
      "defaultValue": "bootstrap",
      "allowedValues": [
        "bootstrap",
        "cluster",
        "all"
      ],
      "metadata": {
        "description": "Deployment mode: bootstrap creates identities/network/RBAC only, cluster creates cluster only, all does both in one run."
      }
    }
  },
  "variables": {
