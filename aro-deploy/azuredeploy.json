          "subnetId": "[resourceId('Microsoft.Network/virtualNetworks/subnets', format('{0}-vnet', parameters('clusterName')), 'master-subnet')]",
          "encryptionAtHost": "Disabled"
        },
        "workerProfiles": [
          {
            "name": "worker",
            "vmSize": "[parameters('workerVmSize')]",
            "diskSizeGB": "[parameters('workerDiskSizeGB')]",
            "subnetId": "[resourceId('Microsoft.Network/virtualNetworks/subnets', format('{0}-vnet', parameters('clusterName')), 'worker-subnet')]",
            "count": "[parameters('workerCount')]",
            "encryptionAtHost": "Disabled"
          }
        ],
        "apiserverProfile": {
