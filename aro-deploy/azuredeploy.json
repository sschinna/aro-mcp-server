    },
    {
      "condition": "[variables('deployBootstrap')]",
      "type": "Microsoft.Network/virtualNetworks/subnets",
      "apiVersion": "2023-09-01",
      "name": "[format('{0}/{1}', format('{0}-vnet', parameters('clusterName')), 'master-subnet')]",
